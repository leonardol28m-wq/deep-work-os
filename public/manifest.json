{
  "manifest_version": 3,
  "name": "Deep Work OS",
  "version": "1.0.0",
  "description": "Transform Chrome into a high-performance work environment. Block distractions, track deep work sessions, measure productivity.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "webNavigation"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Deep Work OS"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked/index.html", "blocked/*", "assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
